// Kerberoasting Activity (RC4 Service Ticket)
// Detects requests for multiple Kerberos service tickets (4769) using weak RC4 encryption (0x17) within a short window. Attackers request service tickets for accounts with SPNs then crack them offline to recover service account passwords. Multiple distinct SPNs from one user/IP indicates automated Kerberoasting. Excludes krbtgt and machine accounts.
// MITRE T1558.003 - Kerberoasting, T1558 - Steal or Forge Kerberos Tickets


dataset = xdr_data
| filter event_type = ENUM.EVENT_LOG and action_evtlog_event_id = 4769
| alter TicketEncryptionType = action_evtlog_data_fields->TicketEncryptionType
| alter ServiceName = action_evtlog_data_fields->ServiceName
| alter TargetUserName = action_evtlog_data_fields->TargetUserName
| alter IpAddress = action_evtlog_data_fields->IpAddress
| filter TicketEncryptionType in ("0x17", "23")
| filter ServiceName != "krbtgt"
| filter ServiceName != null and ServiceName not contains "$"
| filter TargetUserName != null and TargetUserName not contains "$"
| bin _time span = 10m
| comp count_distinct(ServiceName) as Unique_SPNs_Requested, values(ServiceName) as Targeted_Services by _time, TargetUserName, IpAddress, agent_hostname
| filter Unique_SPNs_Requested >= 10
