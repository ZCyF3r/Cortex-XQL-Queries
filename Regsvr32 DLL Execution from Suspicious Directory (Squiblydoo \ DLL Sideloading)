// Regsvr32 DLL Execution from Suspicious Directory (Squiblydoo \ DLL Sideloading)
// Detects regsvr32.exe loading DLLs from user-writable directories such as Temp, AppData, ProgramData, Downloads, Desktop, and Public. Legitimate DLL  registration runs from System32 or Program Files - execution from these paths indicates LOLBin abuse for proxy execution, DLL sideloading, or defense evasion commonly used to launch malware payloads.
// MITRE T1218.010 - System Binary Proxy Execution: Regsvr32, T1574.002 - Hijack Execution Flow: DLL Side-Loading


dataset = xdr_data
| filter event_type = ENUM.PROCESS and event_sub_type = ENUM.PROCESS_START
| filter actor_process_image_name = "regsvr32.exe" or action_process_image_name = "regsvr32.exe"
| filter action_process_image_command_line != null
| filter action_process_image_command_line ~= "(?i)\.dll"
| filter (
    action_process_image_command_line ~= "(?i)\\temp\\"
    or action_process_image_command_line ~= "(?i)\\users\\[^\\]+\\appdata\\"
    or action_process_image_command_line ~= "(?i)\\programdata\\"
    or action_process_image_command_line ~= "(?i)\\users\\[^\\]+\\downloads\\"
    or action_process_image_command_line ~= "(?i)\\users\\[^\\]+\\desktop\\"
    or action_process_image_command_line ~= "(?i)\\users\\public\\"
    or action_process_image_command_line ~= "(?i)\\windows\\temp\\"
    or action_process_image_command_line ~= "(?i)\\appdata\\local\\temp\\"
    or action_process_image_command_line ~= "(?i)\\appdata\\roaming\\"
    or action_process_image_command_line ~= "(?i)\\appdata\\local\\"
)
| fields _time, agent_hostname, actor_process_image_name, actor_process_image_path, actor_process_command_line, action_process_image_name, action_process_image_path, action_process_image_command_line, actor_effective_username, actor_primary_username
