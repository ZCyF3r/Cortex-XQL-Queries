dataset = xdr_data 
| filter agent_os_type = ENUM.AGENT_OS_WINDOWS
| filter actor_process_image_name = "(?i)(Pulse|GlobalProtect-VPN|VPN-Client|Sophos-Connect-Client|vpn)\.exe"
| filter action_process_image_name = "(?i)(rundll32|regsvr32|mshta|wscript|powershell|cmd)\.exe"
| filter action_registry_key_name = "RunOnce"
    and action_registry_value_name = "(?i)(Pulse|VPN|GlobalProtect|Sophos|vpnclient)"
| fields _time, agent_hostname, actor_effective_username, actor_process_image_name, action_process_image_name, actor_process_command_line, action_registry_key_name, action_registry_value_name, actor_process_image_path
