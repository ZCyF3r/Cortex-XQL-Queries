// Title       : Google Drive Credential Harvesting Detection
// Description : Detects access or creation of files with credential-related names
//               indicating potential credential harvesting or sensitive data access
// MITRE       : T1552.004 - Unsecured Credentials, T1530 - Data from Cloud Storage

dataset = google_workspace_drive_raw
| alter UPN = json_extract_scalar(actor, "$.email")
| alter event_name = json_extract_scalar(events, "$.name")
| alter file_title = json_extract_scalar(resourcedetails, "$.title")
| alter file_type = json_extract_scalar(resourcedetails, "$.file_type")
| alter file_id = json_extract_scalar(resourcedetails, "$.id")
| alter relation = json_extract_scalar(resourcedetails, "$.relation")
| alter doc_owner = arrayindex(regextract(events,
    "\"name\":\s*\"owner\",\s*\"value\":\s*\"([^\"]+)\""), 0)
| alter doc_type = arrayindex(regextract(events,
    "\"name\":\s*\"doc_type\",\s*\"value\":\s*\"([^\"]+)\""), 0)
| alter destination_folder = arrayindex(regextract(events,
    "\"name\":\s*\"destination_folder_title\",\s*\"value\":\s*\"([^\"]+)\""), 0)
| alter access_url = arrayindex(regextract(events,
    "\"multivalue\":\s*\[\"([^\"]+)\"\]"), 0)
| filter event_name in ("view", "edit", "create", "access_url")
| filter file_title ~= "(?i)(password|passwd|credential|creds|secret|vault|keychain|keepass|lastpass|bitwarden|login|auth|token|api.key|private.key|ssh|vpn|certificate|pfx|pem|kdbx|wallet|seed.phrase|mnemonic|recovery.code|backup.code|2fa|mfa|otp|pin|passphrase|master.key|access.key|secret.key|config|\.env|database|db.dump|backup)"
| fields _time, UPN, event_name, file_title,
         file_type, file_id, relation,
         doc_owner, doc_type, destination_folder,
         ipaddress
| sort desc _time
//| filter UPN ~= ""
