Device Code Phishing
// Query 1: Unmanaged/non-compliant device + suspicious UA + device code flow
// Query 2: Upstream login pattern - MFA interrupt followed by success (victim completing auth)
// Query 3: Cmsi:Cmsi token replay confirming stolen token is being replayed

dataset = msft_azure_ad_raw
| alter Compliance = json_extract_scalar(deviceDetail, "$.isCompliant")
| alter Managed = json_extract_scalar(deviceDetail, "$.isManaged")
| alter Browser = json_extract_scalar(deviceDetail, "$.browser")
| alter device_code_ua = userAgent
| alter device_code_time = _time
| alter device_code_ip = ipAddress
| alter UPN = userPrincipalName
| filter originalTransferMethod = "deviceCodeFlow"
| filter Managed = "false"
| filter Compliance = "false"
| filter device_code_ua contains "python-requests"
    or device_code_ua contains "-live"
| filter signInTokenProtectionStatus = "unbound"

// Join 1 — upstream login pattern for same user
| join type = inner (
    dataset = msft_o365_azure_ad_raw
    | fields _time, UserId, Operation, ResultStatus, ErrorNumber, ClientIP
    | bin _time span = 10m
    | comp values(ErrorNumber) as ErrorNumbers,
             values(Operation) as Operations,
             values(ResultStatus) as Results,
             values(ClientIP) as ClientIPs,
             count() as event_count
             by _time, UserId
    | filter ErrorNumbers ~= "50074"
        and ErrorNumbers ~= "50199"
        and ErrorNumbers ~= "^0$"
    | filter Operations ~= "UserLoggedIn"
        and Operations ~= "UserLoginFailed"
    | filter Results ~= "Success"
        and not (Results ~= "Failed")
    | alter login_time = _time
    | alter login_upn = UserId
) as logins logins.login_upn = UPN

// Join 2 — Cmsi:Cmsi token replay for same user
| join type = inner (
    dataset = msft_o365_azure_ad_raw
    | alter request_type = arrayindex(regextract(extendedProperties,
        "RequestType\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
    | alter IsCompliance = arrayindex(regextract(extendedProperties,
        "IsCompliant\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
    | alter Compliance_Managed = arrayindex(regextract(extendedProperties,
        "IsCompliantAndManaged\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
    | filter request_type contains "Cmsi"
    | alter cmsi_time = _time
    | alter cmsi_ip = ActorIpAddress
    | alter cmsi_upn = UserId
) as cmsi cmsi.cmsi_upn = UPN

| fields device_code_time, login_time, cmsi_time, UPN, device_code_ip, ClientIPs, cmsi_ip, device_code_ua, appDisplayName, Compliance, Managed, Browser, signInTokenProtectionStatus, ErrorNumbers, Operations, Results, event_count, request_type, IsCompliance, Compliance_Managed
| sort desc device_code_time
