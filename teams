// 


dataset = saas_audit_logs
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig = "CallParticipantDetail"
| alter UserType = json_extract_scalar(raw_log, "$.Attendees[0].RecipientType")
| alter UserName = json_extract_scalar(raw_log, "$.Attendees[0].DisplayName")
| alter UserObjectID = json_extract_scalar(raw_log, "$.Attendees[0].UserObjectId")
| alter UPN = json_extract_scalar(raw_log, "$.Attendees[0].UPN")
| alter Artifact_Session_Start = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].StartTimestamp")
| alter Artifact_Session_End = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].EndTimestamp")
| alter Artifact_Share_ID = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].ScreenShareId")
| alter Artifact_Name = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactSharedName")
| alter CallID = json_extract_scalar(raw_log, "$.CallId")
| alter CallStatus = json_extract_scalar(raw_log, "$.ItemName")
//| filter identity_name = ""
| filter Artifact_Name = "screenShared"
| fields _time, service_type, operation_name_orig, UserType, UserName, UserObjectID, UPN, Artifact_Name, Artifact_Share_ID, Artifact_Session_Start, Artifact_Session_End, CallID, CallStatus, raw_log
