// EvilToken Device Code Phishing Initial Compromise
// Catches the exploitation toolkit UA being used during the device code authentication flow
// https://coralogix.com/blog/evil-token-ai-enabled-device-code-phishing-campaign/


dataset = msft_azure_ad_raw
| filter originalTransferMethod = "deviceCodeFlow"
| filter userAgent contains "kali365-live/1.0.0"
    or (userAgent contains "python-requests/2.31.0" and resourceDisplayName = "Microsoft Graph")
| fields _time, userAgent, userDisplayName, userPrincipalName, resourceDisplayName, location, ipAddress, originalTransferMethod, tokenIssuerName, tokenIssuerType, sessionId
