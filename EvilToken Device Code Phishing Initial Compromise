// EvilToken Device Code Phishing Initial Compromise
// Catches the exploitation toolkit UA being used during the device code authentication flow
// https://coralogix.com/blog/evil-token-ai-enabled-device-code-phishing-campaign/


dataset = msft_azure_ad_raw
| filter originalTransferMethod = "deviceCodeFlow"
| filter userAgent ~= "(?i)(python-requests/2\.31\.0|kali365-live/1\.0\.0)"
    or (userAgent ~= "iPhone OS 18" and userAgent ~= "Version/26\.")
    or userAgent ~= "OS/10\.0\.26200"
| fields _time, userAgent, userDisplayName, userPrincipalName, location, ipAddress, originalTransferMethod, tokenIssuerName, tokenIssuerType, sessionId
