// Microsoft Graph Security Alerts for Cross Product Detection
// Surfaces alerts across all Microsoft Defender products with full evidence enrichment using arraymap extraction across all evidence types
// Covers MDE, MDI, MDCA, MDO, Entra ID Protection via Graph Security API


dataset = msft_graph_security_alerts_raw
| alter evidence_objects = json_extract_array(`evidence`, "$")
// Device Evidence
| alter device_names = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.deviceDnsName")), "@element" != null)
| alter device_os = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.osPlatform")), "@element" != null)
| alter device_version = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.version")), "@element" != null)
| alter device_risk = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.riskScore")), "@element" != null)
// User Evidence
| alter logged_on_user = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.loggedOnUsers[0].accountName")), "@element" != null)
| alter user_upns = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.userAccount.userPrincipalName")), "@element" != null)
| alter user_domains = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.userAccount.domainName")), "@element" != null)
| alter user_sids = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.userAccount.userSid")), "@element" != null)
| alter azure_ad_user_ids = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.userAccount.azureAdUserId")), "@element" != null)
// IP Evidence
| alter ip_addresses = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.ipAddress")), "@element" != null)
| alter ip_countries = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.countryLetterCode")), "@element" != null)
// Process Evidence
| alter process_cmds = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.processCommandLine")), "@element" != null)
| alter process_created = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.processCreationDateTime")), "@element" != null)
// File Evidence
| alter file_names = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.fileDetails.fileName")), "@element" != null)
| alter file_paths = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.fileDetails.filePath")), "@element" != null)
| alter file_sha256 = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.fileDetails.sha256")), "@element" != null)
| alter file_sha1 = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.fileDetails.sha1")), "@element" != null)
| alter file_publishers = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.fileDetails.filePublisher")), "@element" != null)
// URL Evidence
| alter urls = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.url")), "@element" != null)
// Analyzed Message Evidence (Email)
| alter mail_subjects = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.subject")), "@element" != null)
| alter mail_senders = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.senderEmail")), "@element" != null)
| alter mail_recipients = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.recipientEmailAddress")), "@element" != null)
| alter mail_delivery_action = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.deliveryAction")), "@element" != null)
| alter mail_delivery_location = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.deliveryLocation")), "@element" != null)
// Mailbox Evidence
| alter mailbox_addresses = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.primaryAddress")), "@element" != null)
// Network Connection Evidence
| alter net_dest_ips = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.destinationAddress")), "@element" != null)
| alter net_dest_ports = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.destinationPort")), "@element" != null)
| alter net_source_ips = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.sourceAddress")), "@element" != null)
// Azure Resource Evidence
| alter azure_resource_ids = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.resourceId")), "@element" != null)
| alter azure_resource_types = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.resourceType")), "@element" != null)
// Mail Cluster Evidence
| alter mail_cluster_by = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.clusterBy")), "@element" != null)
| alter mail_cluster_count = arrayfilter(arraymap(evidence_objects, json_extract_scalar("@element", "$.messageCount")), "@element" != null)
// Evidence count for triage prioritization
| alter evidence_count = array_length(evidence_objects)
//| filter severity in ("high", "critical")
//| filter status = "new"
//| filter serviceSource ~= ""
//| filter array_length(user_upns) > 0
//| filter array_length(file_sha256) > 0
//| filter array_length(process_cmds) > 0
//| filter title = "'"
//| filter incidentId = ""
| fields _time, title, category, severity, status, classification, determination, serviceSource, productName, incidentId, description, alertweburl, evidence_count, logged_on_user, user_upns, user_domains, user_sids, azure_ad_user_ids, device_names, device_os, device_version, device_risk, ip_addresses, ip_countries, process_cmds, process_created, file_names, file_paths, file_sha256, file_sha1, file_publishers, urls, net_dest_ips, net_dest_ports, net_source_ips, mail_subjects, mail_senders, mail_recipients, mail_delivery_action, mail_delivery_location, mailbox_addresses, azure_resource_ids, azure_resource_types, mail_cluster_by, mail_cluster_count, evidence 
