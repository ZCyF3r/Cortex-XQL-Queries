// Kubernetes Suspicious Namespace & Node Operations
// Detects creation of new namespaces and nodes via API server
// MITRE T1610 - Deploy Container, T1496 - Resource Hijacking


dataset = cloud_audit_logs
| filter resource_type_orig = "k8s.io"
| filter operation_name_orig in ("io.k8s.core.v1.namespaces.create", "io.k8s.core.v1.namespaces.delete", "io.k8s.core.v1.nodes.create", "io.k8s.core.v1.nodes.delete")
| alter principal = json_extract_scalar(raw_log, "$.protoPayload.authenticationInfo.principalEmail")
| alter auth_granted = json_extract_scalar(raw_log, "$.protoPayload.authorizationInfo[0].granted")
| alter auth_resource = json_extract_scalar(raw_log, "$.protoPayload.authorizationInfo[0].resource")
| alter resource_name = json_extract_scalar(raw_log, "$.protoPayload.request.metadata.name")
// Flag operation type
| alter op_type = if(
    operation_name_orig contains "delete", "DESTROY",
    operation_name_orig contains "create", "CREATE",
    "OTHER"
)
//| filter principal ~= ""
| fields _time, principal, operation_name_orig, op_type, resource_name, auth_granted, auth_resource, referenced_resource_name, caller_ip, caller_ip_geolocation, caller_ip_asn_org
