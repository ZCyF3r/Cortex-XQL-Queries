// TeamPCP Trivy Supply Chain - Kubernetes Secrets Exfiltration
// Detects bulk Kubernetes secret enumeration used by TeamPCP stealer
// https://www.microsoft.com/en-us/security/blog/2026/03/24/detecting-investigating-defending-against-trivy-supply-chain-compromise/

dataset = xdr_data
| filter event_type = ENUM.PROCESS
| filter action_process_image_name = "bash"
| filter action_process_command_line contains "kubectl get secrets"
    and action_process_command_line contains "--all-namespaces"
    and action_process_command_line contains "-o json"
    and action_process_command_line contains "|| true"
| fields _time, agent_hostname, actor_effective_username, actor_process_image_name, action_process_image_name, action_process_command_line, actor_process_command_line
