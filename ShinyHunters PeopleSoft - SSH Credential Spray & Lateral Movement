// ShinyHunters PeopleSoft - SSH Credential Spray & Lateral Movement
// Detects the specific ShinyHunters lateral movement pattern: automated SSH spray using sshpass or rapid SSH to multiple hosts with PeopleSoft admin accounts after reading /etc/hosts
// https://www.bleepingcomputer.com/news/security/oracle-peoplesoft-servers-hacked-in-shinyhunters-data-theft-attacks/
// MITRE T1021.004 - Remote Services: SSH, T1078 - Valid Accounts


dataset = xdr_data
| filter event_type = ENUM.PROCESS
| filter action_process_image_name = "sshpass"
    or (action_process_image_name = "ssh"
        and actor_process_image_name ~= "(?i)(bash|sh|dash)"
        and action_process_image_command_line ~= "(?i)(psoft|oracle|linuxadm|psadm|weblogic)")
    or (actor_process_command_line ~= "(?i)(cat /etc/hosts|grep -i peoplesoft|grep -i psoft)"
        and action_process_image_name = "ssh")
| bin _time span = 10m
| comp count() as ssh_count,
         values(action_process_image_command_line) as ssh_commands,
         values(actor_process_command_line) as parent_commands
         by _time, agent_hostname, actor_effective_username
| filter ssh_count >= 3
//| filter agent_hostname ~= ""
| fields _time, agent_hostname, actor_effective_username, ssh_count, ssh_commands, parent_commands
