dataset = google_cloud_logging_raw
| alter
    methodName = protoPayload -> methodName,
    principalEmail = protoPayload -> authenticationInfo.principalEmail,
    ServiceAccountDelegation = json_extract_scalar(protoPayload, "$.authenticationInfo.serviceAccountDelegationInfo[0].firstPartyPrincipal.principalEmail"),
    resourceName = protoPayload -> resourceName,
    jobRegion = json_extract_scalar(protoPayload, "$.resourceLocation.currentLocations[0]"),
    jobID = protoPayload -> request.job_id,
    jobName = protoPayload -> request.job_name,
    caller_ip = protoPayload -> requestMetadata.callerIp
| filter methodName = "dataflow.jobs.create"
