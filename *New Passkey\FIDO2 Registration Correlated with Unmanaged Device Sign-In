// New Passkey\FIDO2 Registration Correlated with Unmanaged Device Sign-In
// Detects a FIDO2 security key / passkey registered to an Entra ID account that correlates to a near-simultaneous sign-in from an unmanaged or non-compliant device. Consistent with a vishing operator guiding a victim through a malicious passkey registration after posing as IT/helpdesk. Ties the persistence action to the suspicious session that performed it. Pink/O-UNC-066, Unit 42 July 2026.
// MITRE T1556.006 - Modify Authentication Process: MFA, T1098.005 - Account Manipulation: Device Registration, T1566.004 - Phishing: Spearphishing Voice

dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig in (
    "User registered security info",
    "Admin registered security info",
    "User registered all required security info"
  )
| alter reg_actor = identity_name
| alter mod_props = json_extract_array(raw_log, "$.targetResources[0].modifiedProperties")
| alter prop_names = arraymap(mod_props, json_extract_scalar("@element", "$.displayName"))
| alter passkey_type_arr = arraymap(mod_props, if(json_extract_scalar("@element", "$.displayName") ~= "(?i)PasskeyType", json_extract_scalar("@element", "$.newValue"), null))
| alter passkey_type = arrayindex(arrayfilter(passkey_type_arr, "@element" != null), 0)
| alter is_passkey = arraymap(mod_props, if(json_extract_scalar("@element", "$.displayName") ~= "(?i)(PasskeyType|publicKeyCredential|Fido2)", "yes", "no"))
// Only passkey/FIDO2 registrations
| filter arraycontains(is_passkey, "yes")
| alter reg_upn = json_extract_scalar(raw_log, "$.targetResources[0].userPrincipalName")
| alter reg_time = _time
| alter reg_ip = caller_ip
// Join to sign-in events for the same user from unmanaged/non-compliant devices
| join type = inner (
    dataset = msft_azure_ad_raw
    | alter signin_compliant = json_extract_scalar(deviceDetail, "$.isCompliant")
    | alter signin_managed = json_extract_scalar(deviceDetail, "$.isManaged")
    | alter signin_device_id = json_extract_scalar(deviceDetail, "$.deviceId")
    | alter signin_trust = json_extract_scalar(deviceDetail, "$.trustType")
    | alter signin_upn = userPrincipalName
    | alter signin_time = _time
    | alter signin_ip = ipAddress
    // Unmanaged OR non-compliant OR no device ID (the KQL condition)
    | filter signin_compliant = "false"
        or signin_managed = "false"
        or signin_device_id = null
        or signin_device_id = ""
    | fields signin_time, signin_upn, signin_ip, signin_compliant,
             signin_managed, signin_device_id, signin_trust,
             location, appDisplayName, userAgent
  ) as s s.signin_upn = reg_upn
// Registration must occur within the sign-in window (-15m to +5m like the KQL)
| filter timestamp_diff(reg_time, signin_time, "MINUTE") <= 15
    and timestamp_diff(reg_time, signin_time, "MINUTE") >= -5
| fields reg_time, signin_time, reg_upn, reg_actor, operation_name_orig, passkey_type, reg_ip, signin_ip, signin_compliant, signin_managed, signin_device_id, signin_trust, location, appDisplayName, userAgent
