// New Passkey\FIDO2 Registration Correlated with Unmanaged Device Sign-In
// Detects a FIDO2 security key / passkey registered to an Entra ID account that correlates to a near-simultaneous sign-in from an unmanaged or non-compliant device. Consistent with a vishing operator guiding a victim through a malicious passkey registration after posing as IT/helpdesk. Ties the persistence action to the suspicious session that performed it. Pink/O-UNC-066, Unit 42 July 2026.
// MITRE T1556.006 - Modify Authentication Process: MFA, T1098.005 - Account Manipulation: Device Registration, T1566.004 - Phishing: Spearphishing Voice


dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig in (
    "User registered security info",
    "Admin registered security info",
    "User registered all required security info"
  )
| filter operation_status_reason_provided = "User registered Fido2 Authentication Method"
| alter
    reg_actor = identity_name,
    reg_upn = json_extract_scalar(raw_log, "$.targetResources[0].userPrincipalName"),
    reg_time = _time,
    reg_ip = caller_ip,
    reg_geo = caller_ip_geolocation,
    reg_asn = caller_ip_asn,
    reg_asn_org = caller_ip_asn_org,
    reg_tunnel_anon = caller_ip_enrichment -> tunnels_anonymous,
    reg_tunnel_operator = caller_ip_enrichment -> tunnels_operator
| join type = inner (
    dataset = cloud_audit_logs
    | filter cloud_provider = ENUM.Azure
    | filter operation_name_orig = "Sign-in activity"
    | alter
        signin_compliant = json_extract_scalar(raw_log, "$.deviceDetail.isCompliant"),
        signin_managed = json_extract_scalar(raw_log, "$.deviceDetail.isManaged"),
        signin_device_id = json_extract_scalar(raw_log, "$.deviceDetail.deviceId"),
        signin_trust = json_extract_scalar(raw_log, "$.deviceDetail.trustType"),
        signin_upn = identity_name,
        signin_time = _time,
        signin_ip = caller_ip,
        signin_asn = caller_ip_asn,
        signin_location = json_extract_scalar(raw_log, "$.location"),
        signin_app = json_extract_scalar(raw_log, "$.appDisplayName"),
        signin_user_agent = json_extract_scalar(raw_log, "$.userAgent")
    | filter signin_compliant = "false"
        or signin_managed = "false"
        or signin_device_id = null
        or signin_device_id = ""
    | fields signin_time, signin_upn, signin_ip, signin_asn, signin_compliant, signin_managed, signin_device_id, signin_trust, signin_location, signin_app, signin_user_agent
  ) as s s.signin_upn = reg_upn
| filter timestamp_diff(reg_time, signin_time, "MINUTE") <= 15
    and timestamp_diff(reg_time, signin_time, "MINUTE") >= -5
| fields reg_time, signin_time, reg_upn, reg_actor, reg_ip, reg_geo, reg_asn, reg_asn_org, reg_tunnel_anon, reg_tunnel_operator, signin_ip, signin_asn, signin_compliant, signin_managed, signin_device_id, signin_trust, signin_location, signin_app, signin_user_agent
