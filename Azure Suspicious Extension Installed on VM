// Suspicious extension installed on Azure VM

// CustomScriptExtension - Execute scripts on VM
// RunCommandHandlerWindows/Linux - RCE capability
// DSCExtension - Powershell desired state configuration
// AADLoginForWindows - Can be used to add unauthorized accounts
// NetworkWatcherAgent - Can be used for network recon


dataset = cloud_audit_logs 
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig = "MICROSOFT.COMPUTE/VIRTUALMACHINES/EXTENSIONS/WRITE"
| filter identity_name != null and identity_name != ""
| filter referenced_resource_name ~= "(?i)CustomScriptExtension|RunCommandHandlerWindows|RunCommandHandlerLinux|DSCExtension|BGInfo|AADLoginForWindows|NetworkWatcherAgentWindows|NetworkWatcherAgentLinux"
| filter operation_status_orig in("Accepted.Created", "Succeeded.", "Started.")
| fields _time, identity_name, identity_invoked_by_name, identity_type, operation_name_orig, referenced_resource_name, caller_ip, caller_ip_geolocation, caller_ip_asn_org, user_agent, region
