// GCP Service Account Creation & Key Generation
// Detects creation of service accounts and service account keys. Long-lived SA keys are credentials that survive password resets and MFA, making them a prime persistence mechanism after cloud compromise. Attacker-created service accounts provide durable identity for lateral movement and access.
// MITRE T1136.003 - Create Account: Cloud Account, T1098.001 - Account Manipulation: Additional Cloud Credentials


dataset = google_cloud_logging_raw
| alter
    methodName = protoPayload -> methodName,
    principalEmail = protoPayload -> authenticationInfo.principalEmail,
    ServiceAccountDelegation = json_extract_scalar(protoPayload, "$.authenticationInfo.serviceAccountDelegationInfo[0].firstPartyPrincipal.principalEmail"),
    resourceName = protoPayload -> resourceName,
    target_service_account_id = protoPayload -> request.account_id,
    target_service_account_display_name = protoPayload -> request.service_account.display_name,
    target_service_account_email = protoPayload -> response.email,
    target_service_account_key_name = protoPayload -> response.name,
    project_id = resource -> labels.project_id,
    OAuth_client_id = protoPayload -> response.oauth2_client_id,
    caller_ip = protoPayload -> requestMetadata.callerIp,
    caller_user_agent = protoPayload -> requestMetadata.callerSuppliedUserAgent
| alter op_type = if(methodName contains "CreateServiceAccount", "SA Creation", methodName contains "CreateServiceAccountKey", "SA Key Creation", "other")
| alter scripted_ua = if(caller_user_agent ~= "(?i)(python(?:-requests)?|curl|wget|go-http|node|axios|google-api|gcloud)", true, false)
| filter methodName in ("google.iam.admin.v1.CreateServiceAccount","google.iam.admin.v1.CreateServiceAccountKey")
//| filter principalEmail = ""
//| filter target_service_account_email = ""
//| filter target_service_account_display_name = ""
| fields _time, methodName, op_type, principalEmail, ServiceAccountDelegation, target_service_account_display_name, target_service_account_email, target_service_account_id, target_service_account_key_name, resourceName, project_id, scripted_ua, caller_ip, caller_user_agent
