// Entra ID Guest User Invited from External Domain
// Detects when external users are invited to the tenant


dataset = cloud_audit_logs 
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig = "Invite external user"
| alter invited_email = json_extract_scalar(raw_log, "$.targetResources[0].userPrincipalName")
| alter invited_domain = arrayindex(regextract(invited_email, "@(.+)$"), 0)
| fields _time, identity_name, identity_invoked_by_name, invited_email, invited_domain, caller_ip, caller_ip_asn, caller_ip_geolocation, user_agent
