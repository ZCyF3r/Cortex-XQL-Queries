// Microsoft Teams Suspicious App Installation & Bot Abuse
// Detects suspicious app installations, custom app creation, and bot additions
// Sideloaded apps bypass Teams store vetting - common attacker persistence technique
// Custom app creation outside dev teams indicates potential C2 bot or data exfil app
// MITRE: T1059.009 - Cloud API, T1543 - Create or Modify System Process


dataset = saas_audit_logs
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig in ("AppInstalled","AppCreated","AppShared","AppUpgraded","BotAddedToTeam","TabAdded")
| alter addon_name = json_extract_scalar(raw_log, "$.AddonName")
| alter addon_guid = json_extract_scalar(raw_log, "$.AddonGuid")
| alter addon_type = json_extract_scalar(raw_log, "$.AddonType")
| alter app_external_id = json_extract_scalar(raw_log, "$.AppExternalId")
| alter azure_ad_app_id = json_extract_scalar(raw_log, "$.AzureADAppId")
| alter app_distribution_mode = json_extract_scalar(raw_log, "$.AppDistributionMode")
| alter team_guid = json_extract_scalar(raw_log, "$.TeamGuid")
| alter team_name = json_extract_scalar(raw_log, "$.TeamName")
| alter target_user = json_extract_scalar(raw_log, "$.TargetUserId")
| alter org_id = json_extract_scalar(raw_log, "$.OrgId")
// Flag high risk distribution modes and operation types
| alter risk_level = if(
    operation_name_orig = "AppCreated", "HIGH",
    app_distribution_mode = "Sideloaded", "HIGH",
    operation_name_orig = "BotAddedToTeam"
        and addon_name != null, "HIGH",
    operation_name_orig = "AppShared", "MEDIUM",
    operation_name_orig = "TabAdded", "MEDIUM", "LOW"
)
// Flag suspicious app names indicating impersonation or malicious tooling
| alter name_risk = if(
    addon_name ~= "(?i)(password|credential|vault|harvest|exfil|tunnel|proxy|backdoor|rat|remote|shell|cmd|powershell|invoke|bypass|hook|intercept|capture|keylog|steal)",
    "SUSPICIOUS_NAME", "OK"
)
| fields _time, identity_name, operation_name_orig, addon_name, addon_guid, addon_type, app_external_id, azure_ad_app_id, app_distribution_mode, team_name, team_guid, target_user, risk_level, name_risk, caller_ip, caller_ip_geolocation, caller_ip_asn_org, user_agent, raw_log
| sort desc _time
//| filter risk_level = "HIGH"
//| filter name_risk = "SUSPICIOUS_NAME"
//| filter identity_name ~= ""
