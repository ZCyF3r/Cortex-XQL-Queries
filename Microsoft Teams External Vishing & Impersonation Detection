// Microsoft Teams External Vishing & Impersonation Detection
// Detects external calls involving screen sharing and impersonation of trusted entities
// Screen share during external call = high risk credential theft / RAT installation vector


dataset = saas_audit_logs
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig = "CallParticipantDetail"
| alter UserType = json_extract_scalar(raw_log, "$.Attendees[0].RecipientType")
| alter UserName = json_extract_scalar(raw_log, "$.Attendees[0].DisplayName")
| alter UserObjectID = json_extract_scalar(raw_log, "$.Attendees[0].UserObjectId")
| alter UPN = json_extract_scalar(raw_log, "$.Attendees[0].UPN")
| alter Artifact_Session_Start = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].StartTimestamp")
| alter Artifact_Session_End = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].EndTimestamp")
| alter Artifact_Share_ID = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].ScreenShareId")
| alter Artifact_Name = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactSharedName")
| alter CallID = json_extract_scalar(raw_log, "$.CallId")
| alter CallStatus = json_extract_scalar(raw_log, "$.ItemName")
//| filter identity_name = ""
| filter Artifact_Name = "screenShared"
| filter identity_name ~= "(?i)(microsoft|helpdesk|help\.desk|it\.support|tech\.support|it\.team|service\.desk|administrator|admin\.team|security\.team|security\.alert|support\.team|apple|google|amazon|paypal|bank|fraud|alert|urgent|account\.security|verification|official)"
    or UserName ~= "(?i)(microsoft|helpdesk|help\.desk|it\.support|tech\.support|it\.team|service\.desk|administrator|admin\.team|security\.team|security\.alert|support\.team|apple|google|amazon|paypal|bank|fraud|alert|urgent|account\.security|verification|official)"
    or UPN ~= "(?i)\.(top|xyz|club|buzz|icu|cyou|sbs|live|online|site|fun|store|vip|work|rest|space|link|click|gq|ml|tk|cf|ga|monster|cfd|beauty|hair|makeup|quest|lol|mom|uno|vodka|beer|kim|loan|win|bid|trade|accountant|faith|science|date|cricket|download|racing|review|country|stream|gdn|cam|party|men|promo)"
    or UserName ~= "(?i)\.(top|xyz|club|buzz|icu|cyou|sbs|live|online|site|fun|store|vip|work|rest|space|link|click|gq|ml|tk|cf|ga|monster|cfd|beauty|hair|makeup|quest|lol|mom|uno|vodka|beer|kim|loan|win|bid|trade|accountant|faith|science|date|cricket|download|racing|review|country|stream|gdn|cam|party|men|promo)"
| fields _time, service_type, operation_name_orig, UserType, UserName, UserObjectID, UPN, Artifact_Name, Artifact_Share_ID, Artifact_Session_Start, Artifact_Session_End, CallID, CallStatus, raw_log
