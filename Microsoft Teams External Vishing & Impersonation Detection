// Microsoft Teams External Vishing & Impersonation Detection
// Detects external calls involving screen sharing and impersonation of trusted entities
// Screen share during external call = high risk credential theft / RAT installation vector
// Includes filtering for Free/abused TLDs, Cheap/throwaway TLDs, Phishing-common TLDs, High-risk specialty TLDs, & PHaaS kit TLDs
// Uncomment for specific identity, screenshare artifact, or username impersonation


dataset = saas_audit_logs
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig = "CallParticipantDetail"
| alter UserType = json_extract_scalar(raw_log, "$.Attendees[0].RecipientType")
| alter UserName = json_extract_scalar(raw_log, "$.Attendees[0].DisplayName")
| alter UserObjectID = json_extract_scalar(raw_log, "$.Attendees[0].UserObjectId")
| alter UPN = json_extract_scalar(raw_log, "$.Attendees[0].UPN")
| alter Artifact_Session_Start = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].StartTimestamp")
| alter Artifact_Session_End = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].EndTimestamp")
| alter Artifact_Share_ID = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactShareSessions[0].ScreenShareId")
| alter Artifact_Name = json_extract_scalar(raw_log, "$.ArtifactsShared[0].ArtifactSharedName")
| alter CallID = json_extract_scalar(raw_log, "$.CallId")
| alter CallStatus = json_extract_scalar(raw_log, "$.ItemName")
//| filter identity_name = "<IDENTITY>"
//| filter Artifact_Name = "screenShared"
| filter identity_name ~= "(?i)\.(top|xyz|club|buzz|icu|cyou|sbs|live|online|site|fun|store|vip|work|rest|space|link|click|gq|ml|tk|cf|monster|cfd|beauty|hair|makeup|quest|lol|mom|uno|vodka|beer|kim|loan|win|bid|trade|accountant|faith|science|date|cricket|download|racing|review|country|stream|gdn|party|promo)"
    or identity_name ~= "(?i)(microsoft|helpdesk|help\.desk|it\.support|tech\.support|it\.team|service\.desk|administrator|admin\.team|security\.team|security\.alert|support\.team|apple|google|amazon|paypal|bank|fraud|alert|urgent|account\.security|verification|official)"
//| filter UserName ~= "(?i)(IT Support|Helpdesk|Help Desk|Corporate|Service Desk|Tech Support|IT Team|IT Department|Security|Admin|Administrator|Password|Account|Support|Compliance|Cyber|SOC|Incident|Notification|Alert|Verify|Verification|Reset|MFA|Authentication)"
| fields _time, identity_name, ExternalUPN, service_type, operation_name_orig, UserType, UserName, UserObjectID, UPN, Artifact_Name, Artifact_Share_ID, Artifact_Session_Start, Artifact_Session_End, CallID, CallStatus, raw_log
