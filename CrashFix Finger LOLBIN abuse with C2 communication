//CrashFix Finger LOLBIN abuse with C2 communication
//Detects finger.exe abuse and correlates with connections to malicious IP

config case_sensitive = false timeframe = 30d

| dataset = xdr_data
| filter event_type = ENUM.PROCESS and event_sub_type = ENUM.PROCESS_START
| filter action_process_image_command_line contains "finger.exe" or
        action_process_image_command_line contains "ct.exe"
    and action_process_image_command_line contains "start" and
        action_process_image_command_line contains "cmd.exe"
| join type = left (
    dataset = xdr_data
    | filter event_type in (ENUM.NETWORK, ENUM.STORY)
    | filter action_remote_ip = "69.67.173.30"
    | fields agent_hostname, action_remote_ip, action_remote_port, actor_process_image_name as network_process
) as network_data
    network_data.agent_hostname = agent_hostname and network_data.action_remote_ip = action_remote_ip
| fields _time, agent_ip_addresses, action_process_image_name, action_process_image_command_line, actor_process_image_name, actor_effective_username, action_remote_ip, network_process
