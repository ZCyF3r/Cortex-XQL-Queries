// TeamPCP Trivy Supply Chain - Google Credentials Harvesting
// Detects Python-initiated process reading GCP credentials
// https://www.microsoft.com/en-us/security/blog/2026/03/24/detecting-investigating-defending-against-trivy-supply-chain-compromise/


dataset = xdr_data
| filter event_type = ENUM.PROCESS
| filter actor_process_command_line contains "python3"
| filter action_process_command_line contains "GOOGLE_APPLICATION_CREDENTIALS"
    and action_process_command_line contains "cat"
    and action_process_command_line contains "2>/dev/null"
| fields _time, agent_hostname, actor_effective_username, actor_process_image_name, action_process_image_name, action_process_command_line, actor_process_command_line
