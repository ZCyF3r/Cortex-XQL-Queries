dataset = msft_azure_ad_raw
| alter Compliance = json_extract_scalar(deviceDetail, "$.isCompliant")
| alter Managed = json_extract_scalar(deviceDetail, "$.isManaged")
| alter Browser = json_extract_scalar(deviceDetail, "$.browser")
| alter device_code_ua = userAgent
| alter device_code_time = _time
| alter device_code_ip = ipAddress
| alter UPN = userPrincipalName
| filter originalTransferMethod = "deviceCodeFlow"
| filter Managed = "false"
| filter Compliance = "false"
| filter device_code_ua contains "python-requests"
    or device_code_ua contains "-live"
//| filter appDisplayName = "Microsoft Office"
| filter signInTokenProtectionStatus = "unbound"
| join type = inner (
    dataset = msft_o365_azure_ad_raw
    | alter request_type = arrayindex(regextract(extendedProperties,
        "RequestType\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
    | alter IsCompliance = arrayindex(regextract(extendedProperties,
        "IsCompliant\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
    | alter Compliance_Managed = arrayindex(regextract(extendedProperties,
        "IsCompliantAndManaged\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
    | filter request_type contains "Cmsi"
    | alter cmsi_time = _time
    | alter cmsi_ip = ActorIpAddress
    | alter cmsi_upn = UserId
) as cmsi cmsi.cmsi_upn = UPN
| filter cmsi_time > device_code_time
    and timestamp_diff(cmsi_time, device_code_time, "SECOND") <= 86400
| fields device_code_time, cmsi_time, UPN,
         device_code_ip, cmsi_ip, device_code_ua,
         appDisplayName, Compliance, Managed, Browser,
         signInTokenProtectionStatus, request_type,
         IsCompliance, Compliance_Managed
| sort desc device_code_time
