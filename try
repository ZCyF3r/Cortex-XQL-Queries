dataset = msft_azure_ad_raw
| filter originalTransferMethod = "deviceCodeFlow"
| fields _time, userPrincipalName, ipAddress, userAgent,
         resourceDisplayName, location
| alter device_code_time = _time
| alter device_code_ip = ipAddress
| alter device_code_ua = userAgent

// Join to Dataset 2 — Cmsi:Cmsi session replay events for same user
| join type = inner (
    dataset = msft_o365_azure_ad_raw
    | alter request_type = arrayindex(regextract(extendedProperties,
        "\"Name\":\\s*\"RequestType\",\\s*\"Value\":\\s*\"([^\"]+)\""), 0)
    | filter request_type contains "Cmsi"
    | fields _time, userPrincipalName, request_type,
             ipAddress, errorNumber, logonError, userAgent
    | alter cmsi_time = _time
    | alter cmsi_ip = ipAddress
) userPrincipalName = userPrincipalName

// Cmsi must occur AFTER device code auth within 2 hour window
| filter cmsi_time > device_code_time
    and cmsi_time <= device_code_time + 7200000

| fields device_code_time, cmsi_time, userPrincipalName,
         device_code_ip, cmsi_ip, device_code_ua,
         request_type, resourceDisplayName,
         location, errorNumber, logonError
