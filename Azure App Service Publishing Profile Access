// Azure App Service Publishing Profile Access
// Detects retrieval of App Service publishing profiles which contain deployment credentials (FTP, Web Deploy, Kudu/SCM) in cleartext
// Attackers use these to deploy webshells and backdoors to the app
// MITRE T1552.001 - Credentials in Files, T1078.004 - Valid Accounts: Cloud


dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig = "MICROSOFT.WEB/SITES/PUBLISHXML/ACTION"
| filter identity_name != null and identity_name != ""
//| filter identity_name ~= ""
| alter resource_name = to_string(referenced_resource_name)
| fields _time, identity_name, identity_invoked_by_name, identity_type, identity_sub_type,  operation_name_orig, operation_status_orig, operation_name, operation_status, resource_name, project, caller_ip,  caller_ip_geolocation, caller_ip_asn_org, user_agent, region
