// EvilToken - Malicious IP Detection
// DigitalOcean, PacketHub and Cloudflare IPs from Coralogix EvilToken article
// 


dataset = msft_azure_ad_raw
| filter authenticationProtocol = "deviceCode"
| filter ipAddress ~= "^(167\.99\.0\.116|104\.248\.200\.231|157\.230\.53\.233|159\.203\.163\.96|162\.243\.166\.119|185\.81\.126\.157|151\.241\.19\.10|172\.67\.152\.123|172\.67\.144\.113)$"
| fields _time, userPrincipalName, authenticationProtocol, resourceDisplayName, ipAddress, location, userAgent
