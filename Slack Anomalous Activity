// Slack Anomalous Activity
// Surfaces Slack's own anomaly detection events including impossible travel, new device access, suspicious IP changes and behavioral anomalies
// MITRE T1078 - Valid Accounts, T1539 - Steal Web Session Cookie


dataset = slack_slack_raw 
| filter action in ("anomaly", "audit_logs_records_searched_anomaly")
| alter UPN = json_extract_scalar(actor, "$.user.email")
| alter DisplayName = json_extract_scalar(actor, "$.user.name")
| alter UserId = json_extract_scalar(actor, "$.user.id")
| alter TeamId = json_extract_scalar(actor, "$.user.team")
| alter SlackType = json_extract_scalar(context, "$.location.type")
| alter SlackId = json_extract_scalar(context, "$.location.id")
| alter SlackDomain = json_extract_scalar(context, "$.location.domain")
| alter ReqUserAgent = json_extract_scalar(context, "$.ua")
| alter SrcIP = json_extract_scalar(context, "$.ip_address")
| alter SessId = json_extract_scalar(context, "$.session_id")
| alter anomaly_JA3 = json_extract_scalar(details, "$.client_ja3_fingerprint")
| alter anomaly_IPdetails = json_extract_scalar_array(details, "$.ip_address_details")
| alter anomaly_location = json_extract_scalar(details, "$.location")
| alter anomaly_previous_IP = json_extract_scalar(details, "$.previous_ua")
| alter anomaly_previous_UA = json_extract_scalar(details, "$.previous_ip_address")
| alter anomaly_reason = json_extract_scalar_array(details, "$.reason")
//| filter UPN = ""
//| filter anomaly_reason = ""
| fields _time, action, DisplayName, UPN, UserId, TeamId, SlackType, SlackId, SlackDomain, ReqUserAgent, SrcIP, SessId, anomaly_JA3, anomaly_location, anomaly_IPdetails, anomaly_previous_IP, anomaly_previous_UA, anomaly_reason
