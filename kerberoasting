ortexql
/*
 * Title: Kerberoasting Activity Detected (Multiple RC4 Service Tickets)
 * Description: Detects a single user requesting multiple Kerberos Service Tickets (TGS) with RC4 encryption for non-machine accounts, indicative of Kerberoasting.
 * Author: detections.ai
 * Date: 2026-05-22
 */
dataset = xdr_data
| filter event_type = ENUM.EVENT_LOG and action_evtlog_event_id = 4769

// Extract required fields from Windows event 4769
| alter TicketEncryptionType = action_evtlog_data_fields->TicketEncryptionType
| alter ServiceName = action_evtlog_data_fields->ServiceName
| alter TargetUserName = action_evtlog_data_fields->TargetUserName
| alter IpAddress = action_evtlog_data_fields->IpAddress

// Filter for RC4 encryption types (0x17 or 23). Attackers downgrade to RC4 as it is significantly easier to crack offline.
| filter TicketEncryptionType in ("0x17", "23")

// Filter out standard TGT renewals and machine accounts (which typically end in $) 
// Machine accounts are ignored because their complex, auto-rotating passwords make them poor targets for Kerberoasting.
| filter ServiceName != "krbtgt"
| filter ServiceName != null and ServiceName not contains "$"

// Group activity into 10-minute windows to identify volume spikes
| bin _time span = 10m
| comp count_distinct(ServiceName) as Unique_SPNs_Requested, values(ServiceName) as Targeted_Services by _time, TargetUserName, IpAddress, agent_hostname

// Detect when 3 or more distinct user SPNs are requested within the timeframe.
// NOTE (False Positives): If legacy applications legitimately request RC4 tickets for multiple services, 
// consider increasing this threshold or explicitly filtering out known service account source IPs using:
// | filter IpAddress not in ("<known_legacy_ip1>", "<known_legacy_ip2>")
| filter Unique_SPNs_Requested >= 3
