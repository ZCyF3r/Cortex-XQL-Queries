dataset = saas_audit_logs 
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig in("MessageSent", "ChatCreated")
| alter sender_domain = arrayindex(regextract(identity_name, "@(.+)$"), 0)
| alter UserChatName = json_extract_scalar(raw_log, "$.Members[0].DisplayName")
| filter sender_domain != "" and sender_domain != null
| filter UserChatName contains "IT Support" or 
    UserChatName contains "Helpdesk" or 
    UserChatName contains "Corporate" or 
    UserChatName contains "Service"
//Filter out known internal domains
//| filter sender_domain != "REPLACE WITH YOUR DOMAIN"
| fields _time, identity_name, UserChatName, sender_domain, operation_name_orig, referenced_resource_name, caller_ip, caller_ip_asn, caller_ip_geolocation, raw_log
