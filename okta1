// Okta Help-Desk Social Engineering -> Account Takeover Detection
// MFA factor reset/deactivation followed by a successful login from the VICTIM within 60 minutes

dataset = okta_sso_raw
| filter eventType in ("user.mfa.factor.reset_all", "system.mfa.factor.deactivate", "user.mfa.factor.deactivate", "user.mfa.factor.update", "device.enrollment.create")
| alter factor_time = _time
| alter display_name = json_extract_scalar(actor, "$.displayName")
| alter UPN = json_extract_scalar(actor, "$.alternateId")
| alter client_ip = json_extract_scalar(client, "$.ipAddress")
| alter target_str = to_string(`target`)
| alter target_UPN = json_extract_scalar(target_str, "$[0].alternateId")
| alter target_name = json_extract_scalar(target_str, "$[0].displayName")
| fields factor_time, eventType, displayMessage, display_name, UPN, client_ip, target_UPN , target_name
| join type = inner (
        dataset = okta_sso_raw
        | filter eventType = "user.session.start"
        | alter login_outcome = json_extract_scalar(outcome, "$.result")
        | filter login_outcome = "SUCCESS"
        | alter login_time = _time
        | alter login_user = json_extract_scalar(actor, "$.alternateId")
        | alter login_ip = json_extract_scalar(client, "$.ipAddress")
        | alter login_country = json_extract_scalar(client, "$.geographicalContext.country")
        | alter login_city = json_extract_scalar(client, "$.geographicalContext.city")
        | alter login_os = json_extract_scalar(client, "$.userAgent.os")
        | alter login_browser = json_extract_scalar(client, "$.userAgent.browser")
        | fields login_time, login_user, login_ip, login_country, login_city, login_os, login_browser
    ) as login login.login_user = target_UPN
| filter timestamp_diff(login_time, factor_time, "MINUTE") > 0
       and timestamp_diff(login_time, factor_time, "MINUTE") <= 60
| fields factor_time, login_time, eventType, display_name, UPN, client_ip, target_UPN, target_name, login_ip, login_country, login_city, login_os, login_browser
| sort desc factor_time
