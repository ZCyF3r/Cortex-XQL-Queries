// BlackFile\Cordial Spider MFA Enrollment via Proxy Infrastructure


dataset = okta_sso_raw
| filter eventtype in (
    "user.mfa.factor.activate",
    "user.mfa.factor.update",
    "user.mfa.factor.reset_all",
    "user.mfa.factor.deactivate",
    "device.enrollment.create",
    "device.lifecycle.activate",
    "device.user.add",
    "system.agent.ad.reset_user_password",
    "user.authentication.sso"
  )
| alter 
    actor_upn = actor -> alternateId,
    actor_name = actor -> displayName,
    outcome_result = outcome -> result,
    outcome_reason = outcome -> reason,
    login_risks = debugContext -> debugData.risk,
    client_ip = client -> ipAddress,
    client_country = client -> geographicalContext.country,
    client_city = client -> geographicalContext.city,
    user_agent = client -> userAgent.rawUserAgent,
    asn_org = securitycontext -> asOrg,
    asn = securitycontext -> asNumber,
    is_proxy = securitycontext -> isProxy
// Known BlackFile associated proxy ASN orgs OR Okta proxy flags & Residential/commercial proxy networks used by BlackFile/Cordial Spider
| filter (
    asn_org ~= "mullvad|netnut|9proxy|infatica|nsocks|oxylabs|oxylab|datacamp|m247|packethub|clouvider|ipxo|proxyline|brightdata|luminati|smartproxy|soax|proxyrack|packetstream"
  ) or is_proxy = "true"
//| filter actor_upn = ""
| fields _time, actor_name, actor_upn, eventType, outcome_result, outcome_reason, login_risks, client_ip, client_country, client_city, asn, asn_org, user_agent, is_proxy
