// ShinyHunters PeopleSoft - SSH Lateral Movement with Admin Accounts
// Detects SSH connections using common PeopleSoft and Oracle administrative accounts (psoft, oracle, linuxadm) for lateral movement
// ShinyHunters script parses /etc/hosts to identify PeopleSoft systemsthen attempts SSH with these accounts using password then key-based auth
// MITRE T1021.004 - Remote Services: SSH, T1078 - Valid Accounts

dataset = xdr_data
| filter event_type = ENUM.PROCESS
| filter action_process_image_name ~= "(?i)(ssh|sshpass|ssh-copy-id)"
    or actor_process_image_name ~= "(?i)(ssh|sshpass)"
| filter action_process_command_line ~= "(?i)(psoft|oracle|linuxadm|psadm|weblogic|bea)"
    or actor_process_command_line ~= "(?i)(psoft|oracle|linuxadm|psadm|weblogic|bea)"
//| filter agent_hostname ~= ""
| fields _time, agent_hostname, actor_effective_username, actor_process_image_name, action_process_image_name, actor_process_command_line, action_process_command_line
