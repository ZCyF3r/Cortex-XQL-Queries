// Google Workspace External Email Forwarding
// Detects email forwarding rules configured to send mail outside the domain indicating potential BEC persistence or insider data exfiltration
// MITRE T1114.003 - Email Collection: Email Forwarding Rule


dataset = google_workspace_user_accounts_raw
| alter UPN = json_extract_scalar(actor, "$.email")
| alter events_str = to_string(`events`)
| alter event_name = arrayindex(regextract(events_str, "\"name\":\s*\"([^\"]+)\""), 0)
| alter External_UPN = arrayindex(regextract(events_str, "\"name\":\s*\"email_forwarding_destination_address\",\s*\"value\":\s*\"([^\"]+)\""), 0)
| filter event_name = "email_forwarding_out_of_domain"
//| filter UPN = ""
//| filter External_UPN ~= "(?i)(@gmail|@yahoo|@hotmail|@outlook|@proton|@tutanota|@guerrilla|@temp-mail|@mailinator)"
| fields _time, event_name, UPN, External_UPN, ipAddress, networkInfo, resourceDetails, events, actor





