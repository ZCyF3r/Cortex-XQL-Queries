// Kubernetes Secrets Enumeration via API Server
// Detects listing, reading, and creation of secrets via the K8s API
// MITRE T1552.007 - Container API, T1528 - Steal Application Access Token


dataset = cloud_audit_logs
| filter resource_type_orig = "k8s.io"
| filter operation_name_orig in ("io.k8s.core.v1.secrets.list", "io.k8s.core.v1.secrets.get", "io.k8s.core.v1.secrets.create", "io.k8s.core.v1.secrets.update", "io.k8s.core.v1.secrets.delete")
| alter principal = json_extract_scalar(raw_log, "$.protoPayload.authenticationInfo.principalEmail")
| alter auth_granted = json_extract_scalar(raw_log, "$.protoPayload.authorizationInfo[0].granted")
| alter auth_resource = json_extract_scalar(raw_log, "$.protoPayload.authorizationInfo[0].resource")
| alter op_risk = if(
    operation_name_orig contains "list", "ENUM",
    operation_name_orig contains "delete", "DESTROY",
    operation_name_orig contains "create", "CREATE",
    operation_name_orig contains "update", "MODIFY",
    "READ"
)
//| filter principal ~= ""
//| filter op_risk = "ENUM"
| fields _time, principal, operation_name_orig, op_risk, auth_granted, auth_resource, referenced_resource_name, caller_ip, caller_ip_geolocation, caller_ip_asn_org
