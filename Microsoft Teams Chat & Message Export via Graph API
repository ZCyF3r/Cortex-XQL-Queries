// Microsoft Teams Chat & Message Export via Graph API
// Detects export of Teams messages, transcripts, recordings and chat retrieval
// Graph API exports typically use automation UAs - python-requests, axios, go-http
// Post-compromise attackers use stolen tokens to silently export chat history


dataset = saas_audit_logs 
| filter operation_name_orig in("ChatRetrieved", "MessagesListed", "TeamsSessionStarted", "TranscriptsExported", "RecordingsExported", "MessagesExported")
| filter service_type = "MicrosoftTeams"
// 
| alter TeamsSessionDevice = json_extract_scalar(raw_log, "$.ObjectId")
| alter TeamsSessionDeviceIP = json_extract_scalar(raw_log, "$.ClientId")
// 
| alter CommType = json_extract_scalar(raw_log, "$.CommunicationType")
| alter ChannelGuid = json_extract_scalar(raw_log, "$.ChannelGuid")
| alter TeamName = json_extract_scalar(raw_log, "$.TeamName")
| alter ItemName = json_extract_scalar(raw_log, "$.ItemName")
| alter TargetUserId = json_extract_scalar(raw_log, "$.TargetUserId")
| alter ChatThreadID = json_extract_scalar(raw_log, "$.ChatThreadId")
| alter DeviceID = json_extract_scalar(raw_log, "$.DeviceId")
//
| alter if_tunnels_anonymous = json_extract_scalar(caller_ip_enrichment, "$.tunnels_anonymous")
| alter tunnels_type = json_extract_scalar(caller_ip_enrichment, "$.tunnels_operator")
//
| alter ua_risk = if(
    user_agent ~= "(?i)(python-requests|axios|go-http|curl|wget|powershell|httpx|aiohttp|node)", "HIGH"
    , user_agent ~= "(?i)(graph|postman|thunder|insomnia)", "MEDIUM", "NONE"
)
| filter identity_name = ""
| fields _time, identity_name, operation_name_orig, TeamsSessionDevice, TeamsSessionDeviceIP, CommType, ChannelGuid, TeamName, ItemName, TargetUserId, ChatThreadID, DeviceID, if_tunnels_anonymous, tunnels_type, ua_risk, user_agent, raw_log 
