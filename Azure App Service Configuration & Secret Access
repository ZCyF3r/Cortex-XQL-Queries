// Azure App Service Configuration & Secret Access
// Detects listing and modification of App Service configuration which contains connection strings, app settings, and secrets in plaintext
// CONFIG/LIST returns all secrets - prime credential theft target
// CONFIG/WRITE injects malicious env vars, startup commands, connection strings
// MITRE T1552.001 - Credentials in Files, T1078.004 - Valid Accounts


dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig in (
    "MICROSOFT.WEB/SITES/CONFIG/LIST/ACTION",
    "MICROSOFT.WEB/SITES/SLOTS/CONFIG/LIST/ACTION",
    "MICROSOFT.WEB/SITES/CONFIG/WRITE",
    "MICROSOFT.WEB/SITES/PUBLISHXML/ACTION"
)
| filter identity_name != null and identity_name != ""
//| filter identity_name ~= ""
//| filter identity_type = "User"
| alter resource_name = to_string(referenced_resource_name)
| alter op_risk = if(
    operation_name_orig = "MICROSOFT.WEB/SITES/PUBLISHXML/ACTION", "Credential Theft - Publish Profile",
    operation_name_orig contains "CONFIG/LIST", "Secret Access - Config List",
    operation_name_orig = "MICROSOFT.WEB/SITES/CONFIG/WRITE", "Config Tampering - Malicious Injection",
    "Other"
)
| fields _time, identity_name, identity_invoked_by_name, identity_type, identity_sub_type,  operation_name_orig, op_risk, operation_status_orig, operation_name, operation_status, resource_name, project, caller_ip,  caller_ip_geolocation, caller_ip_asn_org, user_agent, region
