// EvilToken Device Code Phishing Campaign User Agent Detection
// python-requests/2.31.0 = automated scripting agent
// kali365-live/1.0.0 - confirmed M365 exploitation toolkit UA
// https://coralogix.com/blog/evil-token-ai-enabled-device-code-phishing-campaign/


dataset = msft_azure_ad_raw
| filter originalTransferMethod = "deviceCodeFlow"
| filter userAgent contains "kali365-live/1.0.0"
    or (userAgent contains "python-requests/2.31.0" and resourceDisplayName = "Microsoft Graph")
| fields _time, userAgent, userDisplayName, userPrincipalName, location, ipAddress, resourceDisplayName, originalTransferMethod
