// EvilToken - Malicious User Agent Detection
// python-requests/2.31.0 = automated scripting agent
// kali365-live/1.0.0 = confirmed M365 exploitation toolkit UA



dataset = msft_azure_ad_raw
| filter authenticationProtocol = "deviceCode"
| filter userAgent ~= "(?i)(python-requests/2\.31\.0|kali365-live/1\.0\.0)"
| fields _time, userPrincipalName, authenticationProtocol, resourceDisplayName, ipAddress, location, userAgent
