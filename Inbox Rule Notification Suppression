// Inbox Rule Notification Suppression
// Detects creation or modification of inbox rules designed to hide security and MFA notifications by deleting, marking as read, or moving them to hidden folders. Commonly used post-compromise to suppress alerts about rogue device enrollment, sign-ins, or password changes so the victim never discovers the account takeover. A frequent BEC and ATO persistence technique.
// MITRE T1564.008 - Hide Artifacts: Email Hiding Rules, T1114.003 - Email Collection: Email Forwarding Rule


dataset = saas_audit_logs
| filter service_type = "Exchange"
| filter operation_name_orig in ("New-InboxRule", "Set-InboxRule", "UpdateInboxRules")
| alter
    RuleName = arrayindex(regextract(raw_log, "\"Name\":\s*\"Name\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    ToFolder = arrayindex(regextract(raw_log, "\"Name\":\s*\"MoveToFolder\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    MarkedAs = arrayindex(regextract(raw_log, "\"Name\":\s*\"MarkAsRead\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    DeleteMsg = arrayindex(regextract(raw_log, "\"Name\":\s*\"DeleteMessage\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    ProcessingRules = arrayindex(regextract(raw_log, "\"Name\":\s*\"StopProcessingRules\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    SubjectWords = arrayindex(regextract(raw_log, "\"Name\":\s*\"SubjectContainsWords\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    BodyWords = arrayindex(regextract(raw_log, "\"Name\":\s*\"BodyContainsWords\",\s*\"Value\":\s*\"([^\"]+)\""), 0),
    anonymousTunnel = json_extract_scalar(caller_ip_enrichment, "$.tunnels_anonymous"),
    IsVPN = json_extract_scalar(caller_ip_enrichment, "$.tunnels_operator")
| alter has_trivial_name = if(RuleName = "" or RuleName = null or RuleName ~= "^[\.;,\-_\s]{1,4}$", 1, 0)
| alter has_hide_action = if(DeleteMsg = "True" or MarkedAs = "True"
    or ToFolder in ("Conversation History", "Deleted Items", "RSS Feeds", "RSS Subscriptions", "Junk Email", "Archive"), 1, 0)
| alter targets_security = if(SubjectWords ~= "(?i)(security|mfa|verif|authenticat|sign.in|sign-in|login|password|code|alert|microsoft|account|device|register|2fa|otp|unusual|suspicious)"
    or BodyWords ~= "(?i)(security|mfa|verif|authenticat|sign.in|login|password|code|alert|microsoft|account|device|register|2fa|otp)", 1, 0)
| filter has_hide_action = 1 and (has_trivial_name = 1 or targets_security = 1)
| fields _time, identity_name, operation_name_orig, operation_status, RuleName, ToFolder, MarkedAs, DeleteMsg, ProcessingRules, SubjectWords, BodyWords, has_trivial_name, has_hide_action, targets_security, IsVPN, anonymousTunnel, caller_ip, caller_ip_geolocation, caller_ip_asn, user_agent
