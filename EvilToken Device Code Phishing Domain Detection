// EvilToken Device Code Phishing Domain Detection
// Detects endpoints connecting to confirmed EvilToken phishing infrastructure
// https://coralogix.com/blog/evil-token-ai-enabled-device-code-phishing-campaign/


dataset = xdr_data 
| filter event_type in (ENUM.NETWORK, ENUM.STORY)
| filter dns_query_name ~= "(?i)(flow-open|note-access|drive-mail|store-open|mail-link|form-cloud|vault-cloud|page-sync|file-base|net-web|data-form|sync-vault|file-doc|access-file|data-doc|drive-edge|access-base|cloud-link|view-sync|share-portal|sync-store|open-share|app-edge|data-drive|flow-store|link-app|file-share|view-open|net-open|base-mail|file-drive|sync-link|core-portal|portal-cloud|sync-page|view-portal|vault-access|box-note|form-doc|cloud-access|hub-app|doc-open|sync-portal|file-sync|cloud-view|doc-note|hub-flow|page-mail|form-hub).*workers\.dev"
| fields _time, agent_hostname, actor_effective_username, actor_process_image_name, dns_query_name, action_remote_ip, actor_process_command_line
