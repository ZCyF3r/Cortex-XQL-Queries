// Okta Password Spray \ Credential Stuffing
// Failed logins clustered on a source IP hitting many DISTINCT users.


dataset = okta_sso_raw
| filter eventType = "user.session.start"
| alter
    _time = _time,
    outcome_result = outcome -> result,
    outcome_reason = outcome -> reason,
    actor_upn = actor -> alternateId,
    client_ip = client -> ipAddress,
    client_country = client -> geographicalContext.country,
    user_agent = client -> userAgent.rawUserAgent,
    asn_org = securityContext -> asOrg,
    is_proxy = securityContext -> isProxy
| filter outcome_result = "FAILURE"
| comp
    count() as total_failures,
    count_distinct(actor_upn) as distinct_users,
    count_distinct(user_agent) as distinct_user_agents,
    min(_time) as first_seen,
    max(_time) as last_seen,
    values(outcome_reason) as reasons,
    values(client_country) as countries
  by client_ip, asn_org, is_proxy
| alter fails_per_user = divide(total_failures, distinct_users)
| filter distinct_users >= 10
| sort desc distinct_users
