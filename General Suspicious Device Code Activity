// General Device Code Phishing
// Detects device code flow abuse targeting Microsoft Office and Authentication
// Broker AppIds from unmanaged non-compliant devices with unbound tokens
// MITRE T1528 - Steal Application Access Token, T1621 - MFA Request Generation


dataset = msft_azure_ad_raw
| alter Compliance = json_extract_scalar(deviceDetail, "$.isCompliant")
| alter Managed = json_extract_scalar(deviceDetail, "$.isManaged")
| alter Browser = json_extract_scalar(deviceDetail, "$.browser")
| alter device_code_ua = userAgent
| alter device_code_time = _time
| alter device_code_ip = ipAddress
| alter UPN = userPrincipalName
| filter originalTransferMethod = "deviceCodeFlow"
| filter Managed = "false"
| filter Compliance = "false"
| filter signInTokenProtectionStatus = "unbound"
| filter appId in("d3590ed6-52b3-4102-aeff-aad2292ab01c", "29d9ed98-a469-4536-ade2-f981bc1d605e", "4765445b-32c6-49b0-83e6-1d93765276ca", "1b730954-1685-4b74-9bfd-dac224a7b894", "04b07795-8ddb-461a-bbee-02f9e1bf7b46")
| fields _time, device_code_time, UPN, appId, Compliance, Managed, Browser, device_code_ip, device_code_ua, _device_id, originalTransferMethod, signInTokenProtectionStatus
