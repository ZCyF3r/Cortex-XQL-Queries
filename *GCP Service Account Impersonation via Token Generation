// GCP Service Account Impersonation via Token Generation
// Detects use of the IAM Credentials API to generate tokens or sign data as a service account (GenerateAccessToken, GenerateIdToken, SignBlob, SignJwt). This is one identity assuming a service account's identity - a core privilege escalation and lateral movement technique. Attackers impersonate privileged SAs to access resources without needing the SA's key.
// MITRE T1548.005 - Abuse Elevation Control: Cloud Credentials, T1134 - Access Token Manipulation


dataset = google_cloud_logging_raw
| alter
    methodName = protoPayload -> methodName,
    principalEmail = protoPayload -> authenticationInfo.principalEmail,
    ServiceAccountDelegation = json_extract_scalar(protoPayload, "$.authenticationInfo.serviceAccountDelegationInfo[0].firstPartyPrincipal.principalEmail"),
    resourceName = protoPayload -> resourceName,
    caller_ip = protoPayload -> requestMetadata.callerIp,
    caller_user_agent = protoPayload -> requestMetadata.callerSuppliedUserAgent,
    project_id = json_extract_scalar(resource, "$.labels.project_id")
| filter methodName in (
    "GenerateAccessToken",
    "GenerateIdToken",
    "SignBlob",
    "SignJwt"
)
    or methodName contains "GenerateAccessToken"
    or methodName contains "GenerateIdToken"
    or methodName contains "SignBlob"
    or methodName contains "SignJwt"
// The impersonated SA is the resource being acted on
| alter impersonated_sa = resourceName
// Requested scopes/delegates reveal intent
| alter requested_scopes = json_extract_scalar(protoPayload, "$.request.scope")
| alter delegates = json_extract_scalar(protoPayload, "$.request.delegates")
| alter lifetime = json_extract_scalar(protoPayload, "$.request.lifetime")
// Categorize the impersonation method
| alter impersonation_type = if(
    methodName contains "GenerateAccessToken", "OAuth Access Token",
    methodName contains "GenerateIdToken", "OIDC ID Token",
    methodName contains "SignJwt", "JWT Signing",
    methodName contains "SignBlob", "Blob Signing",
    "Other"
)
// Flag when the caller is a user (not another SA) impersonating - higher risk
| alter caller_is_user = if(principalEmail ~= "(?i)(gserviceaccount\.com)$", "false", "true")
| alter scripted_ua = if(caller_user_agent ~= "(?i)(python(?:-requests)?|curl|wget|go-http|node|axios|google-api|gcloud)", "true", "false")
// Delegation chain present = implicit delegation, notable
| alter has_delegation_chain = if(delegates != null or ServiceAccountDelegation != null, "true", "false")
//| filter principalEmail ~= ""
//| filter caller_is_user = "true"
//| filter has_delegation_chain = "true"
| fields _time, methodName, impersonation_type, principalEmail, caller_is_user, impersonated_sa, ServiceAccountDelegation, has_delegation_chain, delegates, requested_scopes, lifetime, resourceName, project_id, scripted_ua, caller_ip, caller_user_agent
