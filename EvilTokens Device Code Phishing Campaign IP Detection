// EvilToken Malicious IP Detection
// DigitalOcean, PacketHub and Cloudflare IPs from Coralogix EvilToken article
// https://coralogix.com/blog/evil-token-ai-enabled-device-code-phishing-campaign/


dataset = msft_o365_azure_ad_raw 
| filter ActorIpAddress ~= "^(167\.99\.0\.116|104\.248\.200\.231|157\.230\.53\.233|159\.203\.163\.96|162\.243\.166\.119|185\.81\.126\.157|151\.241\.19\.10|172\.67\.152\.123|172\.67\.144\.113|216\.203\.20\.95)$"
    or ActorIpAddress = "2606:4700:3037::6815:388b"
    or incidr(ActorIpAddress, "152.55.176.0/20") = true
    or incidr(ActorIpAddress, "162.220.232.0/22") = true
    or incidr(ActorIpAddress, "162.220.234.0/22") = true
    or incidr(ActorIpAddress, "208.77.244.0/22") = true
    or incidr(ActorIpAddress, "66.33.22.0/23") = true
    or incidr(ActorIpAddress, "69.46.46.0/24") = true
    or incidr(ActorIpAddress, "69.9.164.0/22") = true
    or incidr6(ActorIpAddress, "2607:99c0::/32") = true
| alter request_type = arrayindex(regextract(ExtendedProperties, "\"Name\":\s*\"RequestType\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
| filter request_type = "Cmsi:Cmsi"
| fields _time, UserId, ActorIpAddress, request_type,Operation, ResultStatus, ErrorNumber, LogonError, DeviceProperties
