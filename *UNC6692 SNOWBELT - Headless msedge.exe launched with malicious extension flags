// UNC6692 SNOWBELT - Headless msedge.exe launched with malicious extension flags

dataset = xdr_data
| filter event_type = ENUM.PROCESS and event_sub_type = ENUM.PROCESS_START
| filter action_process_image_name = "msedge.exe" or actor_process_image_name = "msedge.exe"
| filter (
    action_process_command_line contains "--headless" or
    actor_process_command_line contains "--headless"
)
| filter (
    action_process_command_line contains "--load-extension" or
    action_process_command_line contains "--disable-extensions-except" or
    actor_process_command_line contains "--load-extension" or
    actor_process_command_line contains "--disable-extensions-except"
)
| alter cmd = coalesce(action_process_command_line, actor_process_command_line)
| alter has_user_data_dir = if(cmd contains "--user-data-dir", "yes", "no")
| fields _time, agent_hostname, actor_primary_username, actor_process_image_name, actor_process_image_path, actor_process_command_line, action_process_image_name, action_process_image_path, action_process_command_line, has_user_data_dir
