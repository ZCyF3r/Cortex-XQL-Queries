// Microsoft Teams External IT Impersonation
// Detects messages sent or chats created by external/guest users with the pretext of being IT


dataset = saas_audit_logs 
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig in("MessageSent", "ChatCreated")
| alter sender_domain = arrayindex(regextract(identity_name, "@(.+)$"), 0)
| alter UserChatName = json_extract_scalar(raw_log, "$.Members[0].DisplayName")
| alter UPN = json_extract_scalar(raw_log, "$.Members[1].UPN")
| alter UserID = json_extract_scalar(raw_log, "$.UserId")
| filter sender_domain != "" and sender_domain != null
| filter UserChatName ~= "(?i)^(?:\b(?:help(?:desk)?|it|service|support|tech|abuse|admin(?:istrator)?|account|alert|assistant|audit|authentication|azure|compliance|corporate|cyber|domain|duo|emergency|entra|finance|fraud|hr|human|identity|incident|legal|m365|mfa|microsoft|network|notification|okta|operations|password|payable|payroll|reset|security|sharepoint|soc|system|teams|threat|verif(?:y|ication))\b.*(?:admin(?:istrator)?|agent|bot|department|desk|resources|support|technician)?)"
    or UserID ~= "(?i)^(?:(?:\b(?:help|it|service|support|tech|abuse|admin(?:istrator)?|account|alert|assistant|audit|authentication|azure|compliance|corporate|cyber|domain|duo|emergency|entra|finance|fraud|hr|human|identity|incident|legal|m365|mfa|microsoft|network|notification|okta|operations|password|payable|payroll|reset|security|sharepoint|soc|system|teams|threat|verif(?:y|ication))[\._%+\-]?(?:desk|support|admin(?:istrator)?|agent|bot|resources|technician)?).*?@.+)"
| fields _time, identity_name, UserChatName, UserID, sender_domain, UPN, operation_name_orig, referenced_resource_name, caller_ip, caller_ip_asn, caller_ip_geolocation, raw_log
