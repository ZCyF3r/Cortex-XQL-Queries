// AWS EC2 GetPasswordData Detection
// 

dataset = amazon_aws_raw
| filter eventSource = "ec2.amazonaws.com"
| filter eventName = "GetPasswordData"
| alter instance_id = json_extract_scalar(requestParameters, "$.instanceId")
| alter ARN = json_extract_scalar(userIdentity, "$.arn")
| alter Identity = json_extract_scalar(userIdentity, "$.principalId")
| alter Identity_type = json_extract_scalar(userIdentity, "$.type")
| fields _time, eventName, ARN, Identity, Identity_type, instance_id, awsRegion, sourceIPAddress, userAgent, errorCode, errorMessage
