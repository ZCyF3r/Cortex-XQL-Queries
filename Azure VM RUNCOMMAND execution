// Azure VM RUNCOMMAND execution

dataset = cloud_audit_logs 
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig = "MICROSOFT.COMPUTE/VIRTUALMACHINES/RUNCOMMAND/ACTION"
| filter identity_name != null and identity_name != ""
| fields _time, identity_name, identity_invoked_by_name, identity_type, operation_name_orig, referenced_resource_name, caller_ip, caller_ip_geolocation, caller_ip_asn_org, user_agent, region
