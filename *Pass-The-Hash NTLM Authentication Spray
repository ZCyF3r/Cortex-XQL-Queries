// NTLM Authentication Spray Across Multiple Hosts
// Detects a single account or source IP authenticating via NTLM (LogonType 3) to multiple hosts within a short window - a pattern consistent with credential spraying, pass-the-hash lateral movement, or NTLM relay.
// MITRE T1110.003 - Password Spraying, T1550.002 - Pass the Hash, T1021.002 - SMB/Windows Admin Shares


dataset = xdr_data
| filter event_type = ENUM.EVENT_LOG and action_evtlog_event_id = 4624
| alter LogonType = action_evtlog_data_fields->LogonType
| alter AuthenticationPackageName = action_evtlog_data_fields->AuthenticationPackageName
| alter LogonProcessName = action_evtlog_data_fields->LogonProcessName
| alter WorkstationName = action_evtlog_data_fields->WorkstationName
| alter TargetUserName = action_evtlog_data_fields->TargetUserName
| alter IpAddress = action_evtlog_data_fields->IpAddress
| filter LogonType = "3"
| filter AuthenticationPackageName = "NTLM"
| filter LogonProcessName = "NtLmSsp"
| filter TargetUserName != null and TargetUserName not contains "$"
| alter is_workstation_anomalous = if(WorkstationName = null or WorkstationName = "" or WorkstationName = "-", true, false)
| bin _time span = 10m
| comp count_distinct(agent_hostname) as Unique_Hosts_Targeted, values(agent_hostname) as Targeted_Hosts by _time, TargetUserName, IpAddress
| filter Unique_Hosts_Targeted >= 2
