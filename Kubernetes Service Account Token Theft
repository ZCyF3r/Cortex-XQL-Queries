// Kubernetes Service Account Token Theft
// Detects non-legit processes reading the service accoutn token


dataset = xdr_data 
| filter event_type = ENUM.FILE
// Service account token path inside containers
| filter action_file_path contains "/var/run/secrets/kubernetes.io/serviceaccount"
| filter action_file_name in("token", "ca.crt", "namespace")
// Exclude legit kubernetes system processes
| filter actor_process_image_name not in("kubelet", "kube-proxy", "containerd", "dockerd", "datadog-agent", "agent", "cloudwatch-agent", "amazon-cloudwatch-agent", "fluent-bit", "fluentd", "promethus", "node_exporter", "otelcol", "otelcol-contrib", "filebeat", "metricbeat", "telegraf", "splunk", "splunkd", "newrelic-infra", "dynatrace", "aws-k8s-agent", "controller", "nginx-ingress-controller", "coredns", "wiz-admission-controller", "wiz-sensor")
| fields _time, agent_hostname, actor_effective_username, actor_process_image_name, actor_process_image_command_line, action_file_name, action_file_path, actor_process_image_path
