dataset = saas_audit_logs 
| filter service_type = "MicrosoftTeams"
| filter operation_name_orig in("AppPublishedToCatalog", "AppUpdatedInCatalog")
| alter AddonName = json_extract_scalar(raw_log, "$.AddOnName")
| alter AddonType = json_extract_scalar(raw_log, "$.AddOnType")
| alter AddonGuid = json_extract_scalar(raw_log, "$.AddOnGuid")
| alter AppDistro = json_extract_scalar(raw_log, "$.AppDistributionMode")
| alter ExternalAppId = json_extract_scalar(raw_log, "$.AppExternalId")
//| filter caller_ip_asn_org !~= "(?i)(microsoft|azure)"
//| filter identity_name ~= ""
| fields _time, operation_name_orig, identity_name, AddonName, AddonGuid, AddonType, AppDistro, ExternalAppId, caller_ip, caller_ip_asn_org, caller_ip_geolocation, raw_log
