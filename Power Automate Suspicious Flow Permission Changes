// Power Automate Suspicious Flow Permission Changes
// Detects flows being shared or permissions modified post compromised
// Filter out or in depending on what you're looking for


dataset = saas_audit_logs
| filter service_type in ("PowerPlatform", "MicrosoftFlow")
| filter operation_name_orig in ("PutPermissions", "CreateRoleAssignment")

//CreateRoleAssignments Details
| alter RoleCreation = arrayindex(regextract(raw_log, "\"Name\":\s*\"powerplatform.analytics.resource.authorization.createdon\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
| alter RoleName = arrayindex(regextract(raw_log, "\"Name\":\s*\"powerplatform.analytics.resource.authorization.role_definition.name\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
| alter AssignID = arrayindex(regextract(raw_log, "\"Name\":\s*\"powerplatform.analytics.resource.authorization.role_assignment.id\",\s*\"Value\":\s*\"([^\"]+)\""), 0)
| alter DefinitionID = arrayindex(regextract(raw_log, "\"Name\":\s*\"powerplatform.analytics.resource.authorization.role_definition.id\",\s*\"Value\":\s*\"([^\"]+)\""), 0)

//PutPermission Details
| alter UserUPN = json_extract_scalar(raw_log, "$.UserUPN")
| alter RecipientUPN = json_extract_scalar(raw_log, "$.RecipientUPN")
| alter FlowConnectorNames = json_extract_scalar(raw_log, "$.FlowConnectorNames")
| alter FlowDetailsUrl = json_extract_scalar(raw_log, "$.FlowDetailsUrl")
| alter tunnels_anonymous = json_extract_scalar(caller_ip_enrichment, "$.tunnels_anonymous")
| alter tunnels_type = json_extract_scalar(caller_ip_enrichment, "$.tunnels_type")
| fields _time, identity_name, operation_name_orig, referenced_resource_name, RoleCreation, RoleName, AssignID, DefinitionID, UserUPN, RecipientUPN, FlowConnectorNames, FlowDetailsUrl, operation_status, caller_ip, caller_ip_asn, caller_ip_geolocation, tunnels_anonymous, tunnels_type, project, raw_log
