// Azure App Service Network Tunneling & Service Disruption
// Detects VPN site creation for network tunneling and start/stop operations
// VPNSITES/WRITE = hybrid connection to pivot into on-prem or other networks
// STOP/START = service disruption or restart to load malicious config
// MITRE T1572 - Protocol Tunneling, T1489 - Service Stop


dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig in (
    "MICROSOFT.WEB/SITES/VPNSITES/WRITE",
    "MICROSOFT.WEB/SITES/STOP/ACTION",
    "MICROSOFT.WEB/SITES/START/ACTION"
)
| filter identity_name != null and identity_name != ""
| alter resource_name = to_string(referenced_resource_name)
| alter op_risk = if(
    operation_name_orig = "MICROSOFT.WEB/SITES/VPNSITES/WRITE", "Network Tunneling - Hybrid Connection",
    operation_name_orig = "MICROSOFT.WEB/SITES/STOP/ACTION", "Service Disruption - Stop",
    operation_name_orig = "MICROSOFT.WEB/SITES/START/ACTION", "Service Restart - Config Reload",
    "Other"
)
//| filter identity_name ~= ""
| fields _time, identity_name, identity_invoked_by_name, identity_type, identity_sub_type,  operation_name_orig, op_risk, operation_status_orig,  resource_name, caller_ip,  caller_ip_geolocation, caller_ip_asn_org,  user_agent, region
