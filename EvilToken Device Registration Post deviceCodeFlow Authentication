// EvilToken Device Registration Post deviceCodeFlow Authentication
// Detects new devices registered in Entra ID within short window of deviceCodeFlow auth
// This is the PRT acquisition TTP - gives attackers persistent MFA-bypass access
// Join: deviceCodeFlow auth -> device registration by same user within 1hr


dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig in ("Add device", "Register device", "Add registered owner to device", "Update device")
| filter identity_name != "Microsoft Online Services"
    and identity_invoked_by_name != "Microsoft Online Services"
| bin _time span = 1h
| join type = inner conflict_strategy = both (
    dataset = msft_azure_ad_raw
    | filter originalTransferMethod = "deviceCodeFlow"
    | fields _time, userPrincipalName, ipAddress, userAgent
    | bin _time span = 1h
) as devicecode devicecode.userPrincipalName = identity_name and devicecode._time = _time
| fields _time, identity_name, operation_name_orig, referenced_resource_name, caller_ip, caller_ip_geolocation, user_agent, ipAddress, userAgent



