// Azure blob storage account key access
// Detects blob access authenticated via storage account key1 & key2

dataset = cloud_audit_logs
| filter cloud_provider = ENUM.Azure
| filter operation_name_orig contains "blob"
| filter identity_name ~= "(?i)^key[12]"
| filter identity_type = "token"
| filter identity_sub_type = "key"
| filter operation_status_orig_code = "200"
| filter operation_status_reason_provided = "Success"
| fields _time, identity_name, identity_type, identity_invoked_by_sub_type, operation_name_orig, referenced_resource_name, caller_ip, caller_ip_geolocation, caller_ip_asn_org, user_agent, region
